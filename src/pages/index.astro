<style>
  /* Puedes conservar los estilos que ya tengas del Loader y las letras, y abajo agregas esto: */

  #beach {
    position: relative;
    width: 100%;
    height: 100vh;      /* Altura extra para compensar el solapamiento */
    margin-top: -30vh;   Empuja la sección un 30% encima del Hero
    overflow: hidden;
    background: transparent;
    z-index: 2;         /* Obliga a la playa a pasar por encima del video del Hero */
  }
</style>

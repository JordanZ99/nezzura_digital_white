  }

  #cotizacion-section .cotizacion-inner {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    padding: clamp(80px, 10vh, 140px) 40px clamp(80px, 10vh, 140px);
    box-sizing: border-box;
  }

  #cotizacion-section .cotizacion-header {
    text-align: center;
    margin-bottom: clamp(40px, 6vh, 80px);
  }

  #cotizacion-section .cotizacion-header h2 {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(28px, 3vw, 56px);
    letter-spacing: 0.05em;
    color: #ffffffff;
    margin: 0 0 12px 0;
    text-transform: uppercase;
  }

  #cotizacion-section .cotizacion-header .cotizacion-sub {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(15px, 1.1vw, 20px);

    color: #ffffffff;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  #cotizacion-section .cotizacion-content {
    display: flex;
    align-items: center;
    gap: clamp(32px, 4vw, 64px);
  }

  #cotizacion-section .cotizacion-image {
    flex: 1;
    min-width: 0;
  }

  #cotizacion-section .cotizacion-image img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
  }

  #cotizacion-section .cotizacion-accordion {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #cotizacion-section .accordion-item {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    overflow: hidden;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  #cotizacion-section .accordion-item:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.18);
  }

  #cotizacion-section .accordion-item.active {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.22);
  }

  #cotizacion-section .accordion-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 22px 24px;
    cursor: pointer;
    user-select: none;
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    color: inherit;
    font-family: inherit;
  }

  #cotizacion-section .accordion-header:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.5);
    outline-offset: -2px;
    border-radius: 16px;
  }

  #cotizacion-section .accordion-title {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 600;
    font-size: clamp(14px, 1.1vw, 18px);
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    flex: 1;
    transition: color 0.3s ease;
  }

  #cotizacion-section .accordion-item.active .accordion-title {
    color: #ffffff;
  }

  #cotizacion-section .accordion-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    color: rgba(255, 255, 255, 0.4);
  }

  #cotizacion-section .accordion-item.active .accordion-icon {
    transform: rotate(180deg);
    color: #ffffff;
  }

  #cotizacion-section .accordion-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                padding 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #cotizacion-section .accordion-item.active .accordion-body {
    max-height: 400px;
  }

  #cotizacion-section .accordion-body-inner {
    padding: 0 24px 24px 24px;
  }

  #cotizacion-section .card-desc {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 700;
    font-size: clamp(12px, 0.8vw, 14px);
    line-height: 1.7;
    color: #e8e8e8;
    margin: 0 0 18px 0;
    text-transform: uppercase;
  }

  #cotizacion-section .card-price {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 600;
    font-size: clamp(20px, 1.6vw, 28px);
    color: #ffffff;
    margin: 0 0 4px 0;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  #cotizacion-section .card-time {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(11px, 0.7vw, 13px);
    color: #ffffff;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  #cotizacion-section .card-includes {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 700;
    font-size: clamp(11px, 0.7vw, 13px);
    color: #ffffff;
    margin: 16px 0 0 0;
    padding-top: 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    line-height: 1.6;
    text-transform: uppercase;
  }

  #cotizacion-section .card-includes strong {
    color: #b3b3b3;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    #cotizacion-section .cotizacion-inner {
      padding: 80px 24px;
    }

    #cotizacion-section .cotizacion-header {
      margin-bottom: 40px;
    }

    #cotizacion-section .cotizacion-content {
      flex-direction: column-reverse;
      gap: 32px;
    }

    #cotizacion-section .cotizacion-image img {
      max-width: 320px;
      margin: 0 auto;
    }

    #cotizacion-section .accordion-header {
      padding: 18px 20px;
      gap: 12px;
    }

    #cotizacion-section .accordion-body-inner {
      padding: 0 20px 20px 20px;
    }
  }
</style>


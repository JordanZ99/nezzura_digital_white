---
const web3FormsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || "";
---
<style>
  #contact-section {
    background: #000000;
    width: 100%;
    position: relative;
    box-sizing: border-box;
  }

  #contact-section .contact-inner {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    padding: clamp(80px, 10vh, 140px) 40px clamp(80px, 10vh, 140px);
    box-sizing: border-box;
  }

  #contact-section .contact-header {
    text-align: center;
    margin-bottom: clamp(40px, 6vh, 72px);
  }

  #contact-section .contact-header h2 {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(28px, 3vw, 56px);
    letter-spacing: 0.05em;
    color: #ffffff;
    margin: 0 0 12px 0;
    text-transform: uppercase;
  }

  #contact-section .contact-header .contact-sub {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 400;
    font-size: clamp(15px, 1.1vw, 20px);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  #contact-section .contact-layout {
    display: flex;
    align-items: flex-start;
    gap: clamp(40px, 5vw, 80px);
  }

  #contact-section .contact-info {
    flex: 1;
    min-width: 0;
  }

  #contact-section .contact-info h3 {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(18px, 1.4vw, 26px);
    color: #ffffff;
    margin: 0 0 16px 0;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  #contact-section .contact-info p {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 400;
    font-size: clamp(14px, 1vw, 17px);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 32px 0;
  }

  #contact-section .contact-detail {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
  }

  #contact-section .contact-detail-icon {
    width: 20px;
    height: 20px;
    color: rgba(255, 255, 255, 0.4);
    flex-shrink: 0;
  }

  #contact-section .contact-detail span {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 400;
    font-size: clamp(13px, 0.9vw, 15px);
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  #contact-section .contact-form-wrap {
    flex: 1;
    min-width: 0;
  }

  #contact-section .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  #contact-section .form-row {
    display: flex;
    gap: 20px;
  }

  #contact-section .form-group {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  #contact-section .form-group label {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(11px, 0.7vw, 13px);
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  #contact-section .form-group input,
  #contact-section .form-group textarea {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 400;
    font-size: clamp(14px, 1vw, 16px);
    color: #ffffff;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 16px 18px;
    outline: none;
    transition: border-color 0.3s ease, background 0.3s ease;
    width: 100%;
    box-sizing: border-box;
  }

  #contact-section .form-group input::placeholder,
  #contact-section .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  #contact-section .form-group input:focus,
  #contact-section .form-group textarea:focus {
    border-color: rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.09);
  }

  #contact-section .form-group textarea {
    min-height: 120px;
    resize: vertical;
  }

  #contact-section .form-submit {
    align-self: flex-start;
  }

  #contact-section .form-submit button {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(13px, 0.9vw, 15px);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #000000;
    background: #ffffff;
    border: none;
    border-radius: 12px;
    padding: 16px 40px;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
  }

  #contact-section .form-submit button:hover {
    background: rgba(255, 255, 255, 0.88);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.15);
  }

  #contact-section .form-submit button:active {
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    #contact-section .contact-inner {
      padding: 80px 24px;
    }

    #contact-section .contact-layout {
      flex-direction: column;
      gap: 48px;
    }

    #contact-section .form-row {
      flex-direction: column;
      gap: 20px;
    }

    #contact-section .form-submit {
      align-self: stretch;
    }

    #contact-section .form-submit button {
      width: 100%;
    }
  }
</style>

<section id="contact-section">
  <div class="contact-inner">
    <div class="contact-header">
      <h2>HABLEMOS</h2>
      <p class="contact-sub">Cuéntanos sobre ti</p>
    </div>
    <div class="contact-layout">
      <div class="contact-info">
        <h3>Tu idea merece empezar hoy</h3>
        <p>Escríbenos a través del formulario. Cuéntanos sobre tu visión y nos pondremos en contacto contigo a la brevedad para hacerlo realidad de forma segura.</p>
      </div>
      <div class="contact-form-wrap">
        <form class="contact-form">
          <!-- Web3Forms Integration -->
          <input type="hidden" name="access_key" value={web3FormsKey} />
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />
          
          <div class="form-row">
            <div class="form-group">
              <label for="contact-name">Nombre *</label>
              <input type="text" id="contact-name" name="name" placeholder="Tu nombre completo" required />
            </div>
            <div class="form-group">
              <label for="contact-email">Correo *</label>
              <input type="email" id="contact-email" name="email" placeholder="tu@correo.com" required />
            </div>
          </div>
          <div class="form-group">
            <label for="contact-company">Empresa</label>
            <input type="text" id="contact-company" name="company" placeholder="Nombre de tu empresa" />
          </div>
          <div class="form-group">
            <label for="contact-message">Mensaje</label>
            <textarea id="contact-message" name="message" placeholder="Cuéntanos sobre tu proyecto, tu idea o lo que necesitas..."></textarea>
          </div>
          <div class="form-submit">
            <button type="submit">ENVIAR MENSAJE</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector('.contact-form') as HTMLFormElement | null;
  
  if (form) {
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (submitBtn) {
      const originalText = submitBtn.textContent || 'ENVIAR MENSAJE';

      form.addEventListener('submit', async function(e) {
        e.preventDefault();

        // Check honeypot for bots
        const botcheck = form.querySelector('input[name="botcheck"]') as HTMLInputElement | null;
        if (botcheck && botcheck.checked) {
          return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'ENVIANDO...';
        submitBtn.style.opacity = '0.7';

        const formData = new FormData(form);
        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        try {
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: json
          });

          const result = await response.json();
          
          if (response.status === 200) {
            submitBtn.textContent = '¡ENVIADO CON ÉXITO!';
            submitBtn.style.background = '#10B981'; // green color
            submitBtn.style.color = '#ffffff';
            submitBtn.style.opacity = '1';
            form.reset();
          } else {
            submitBtn.textContent = 'ERROR AL ENVIAR';
            submitBtn.style.background = '#EF4444'; // red color
            submitBtn.style.color = '#ffffff';
            submitBtn.style.opacity = '1';
            console.error(result);
            alert(result.message || 'Hubo un error al enviar el mensaje. Por favor, intenta de nuevo.');
          }
        } catch (error) {
          submitBtn.textContent = 'ERROR DE CONEXIÓN';
          submitBtn.style.background = '#EF4444';
          submitBtn.style.color = '#ffffff';
          submitBtn.style.opacity = '1';
          console.error(error);
          alert('Hubo un problema de red. Por favor, verifica tu conexión.');
        } finally {
          setTimeout(() => {
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
            submitBtn.style.background = '';
            submitBtn.style.color = '';
            submitBtn.style.opacity = '';
          }, 4000);
        }
      });
    }
  }
</script>


<style>
  #hero {
    position: relative;
    width: 100%;
    height: 100vh;
    background: #ffffff;
    overflow: visible;
  }

  #vimeo-wrap {
    position: absolute;
    inset: 0;
    overflow: visible;
    z-index: 1;
  }

  #vimeo-wrap video {
    position: absolute;
    top: -4%;
    left: -4%;
    width: 108%;
    height: 108%;
    object-fit: cover;
    pointer-events: none;
  }
</style>

<section id="hero">
  <div id="vimeo-wrap">
    <video 
      src="/spin3d.mp4" 
      autoplay 
      loop 
      muted 
      playsinline
      preload="auto">
    </video>
  </div>
</section>

<script>
  (function () {
    const hero = document.getElementById('hero');
    if (!hero) return;

    let ticking = false;

    function updateOpacity() {
      const rect = hero.getBoundingClientRect();
      const wh = window.innerHeight;

      // El hero mide 100vh. La opacidad va de 1 a 0 a medida que
      // el hero se desplaza hacia arriba y sale del viewport.
      // rect.top: 0 → -wh  (hero pasando hacia arriba)
      const start = 0;          // empieza a desvanecer cuando el top del hero toca el borde superior
      const end = -wh;          // completamente invisible cuando el hero ha subido 100vh
      const progress = Math.max(0, Math.min(1, (rect.top - start) / (end - start)));
      // progress: 0 → 1
      const opacity = 1 - progress;

      hero.style.opacity = opacity;
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateOpacity);
        ticking = true;
      }
    }, { passive: true });

    updateOpacity();
  })();
</script>

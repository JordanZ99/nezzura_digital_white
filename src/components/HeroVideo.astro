<style>
  #hero {
    position: relative;
    width: 100%;
    height: 100vh;
    background: #ffffff;
    overflow: visible;
  }

  #vimeo-wrap {
    position: absolute;
    inset: 0;
    overflow: visible;
    z-index: 1;
  }

  #vimeo-wrap iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 120vh;
    height: 120vw;
    transform: translate(calc(-50% - 130px), -50%) rotate(270deg);
    border: none;
    pointer-events: none;
  }

  @media (max-width: 767px) {
    #vimeo-wrap iframe {
      width: 100vw;
      height: 56.25vw;
      min-height: 100vh;
      min-width: 177.78vh;
      transform: translate(-50%, -50%);
    }
  }
</style>

<section id="hero">
  <div id="vimeo-wrap">
    <iframe
      src="https://player.vimeo.com/video/1145256182?background=1&autoplay=1&loop=1&muted=1&playsinline=1&dnt=1"
      allow="autoplay; fullscreen"
      title="Nezzura background video"
    ></iframe>
  </div>
</section>

<script>
  (function () {
    const hero = document.getElementById('hero');
    if (!hero) return;

    let ticking = false;

    function updateOpacity() {
      const rect = hero.getBoundingClientRect();
      const wh = window.innerHeight;

      // El hero mide 100vh. La opacidad va de 1 a 0 a medida que
      // el hero se desplaza hacia arriba y sale del viewport.
      // rect.top: 0 → -wh  (hero pasando hacia arriba)
      const start = 0;          // empieza a desvanecer cuando el top del hero toca el borde superior
      const end = -wh;          // completamente invisible cuando el hero ha subido 100vh
      const progress = Math.max(0, Math.min(1, (rect.top - start) / (end - start)));
      // progress: 0 → 1
      const opacity = 1 - progress;

      hero.style.opacity = opacity;
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateOpacity);
        ticking = true;
      }
    }, { passive: true });

    updateOpacity();
  })();
</script>

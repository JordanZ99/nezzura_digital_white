<style>
  #hero {
    position: relative;
    width: 100%;
    height: 100vh;
    background: #ffffff;
    overflow: visible;
  }

  #vimeo-wrap {
    position: absolute;
    inset: 0;
    overflow: visible;
    z-index: 1;
  }

  #vimeo-wrap iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 120vh;
    height: 120vw;
    transform: translate(calc(-50% - 130px), -50%) rotate(270deg);
    border: none;
    pointer-events: none;
  }

  @media (max-width: 767px) {
    #vimeo-wrap iframe {
      width: 100vw;
      height: 56.25vw;
      min-height: 100vh;
      min-width: 177.78vh;
      transform: translate(-50%, -50%);
    }
  }
</style>

<section id="hero">
  <div id="vimeo-wrap">
    <iframe
      src="https://player.vimeo.com/video/1145256182?background=1&autoplay=1&loop=1&muted=1&playsinline=1&dnt=1"
      allow="autoplay; fullscreen"
      title="Nezzura background video"
    ></iframe>
  </div>
</section>

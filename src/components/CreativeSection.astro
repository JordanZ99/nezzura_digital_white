<style>
  #creative-section {
    position: relative;
    width: 100%;
    min-height: 350vh;
    background: #ffffff;
    box-sizing: border-box;
    z-index: 3;
  }

  #creative-section .creative-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    box-sizing: border-box;
  }

  #creative-section .creative-left {
    width: 50%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    box-sizing: border-box;
    padding-top: 8vh;
  }

  #creative-section .creative-text {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(18px, 2.2vw, 26px);
    letter-spacing: 0.01em;
    line-height: 1.2;
    text-transform: uppercase;
    color: #080808;
    margin: 0;
    padding: clamp(20px, 3vh, 40px) 0 0 clamp(20px, 2vw, 40px);
    box-sizing: border-box;
    white-space: pre-line;
  }

  #creative-section .creative-cta {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(16px, 1vw, 22px);
    line-height: 1.2;
    text-transform: uppercase;
    color: #888888;
    margin: 100px 0 0 0;
    padding: 0 0 0 clamp(20px, 2vw, 40px);
    box-sizing: border-box;
    white-space: pre-line;
  }

  #creative-section .creative-right {
    width: 50%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    box-sizing: border-box;
    padding-top: 12vh;
  }

  #creative-section .image-stack {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }

  #creative-section .image-stack img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #creative-section .image-reveal {
    will-change: clip-path;
    clip-path: inset(100% 0 0 0);
  }

  @media (max-width: 768px) {
    #creative-section .creative-sticky {
      flex-direction: column;
    }
    #creative-section .creative-left {
      width: 100%;
      height: 50%;
      padding: 0;
      justify-content: center;
    }
    #creative-section .creative-text {
      max-width: 100%;
      font-size: clamp(15px, 3.5vw, 20px);
      padding: 20px 25px 0 25px;
    }
    #creative-section .creative-cta {
      font-size: clamp(13px, 3.5vw, 18px);
      padding: 0 25px 0 25px;
      margin: 20px 0 0 0;
    }
    #creative-section .creative-right {
      width: 100%;
      height: 50%;
      padding: 8px;
    }
  }
</style>

<section id="creative-section">
  <div class="creative-sticky">
    <div class="creative-left">
      <p class="creative-text">ESTRUCTURAS EFICIENTES, DISEÑOS PREMIUM. EN NEZZURA CONSTRUIMOS LA IMAGEN DIGITAL QUE TU MARCA SE MERECE. CADA DETALLE ESTÁ PENSADO PARA QUE QUIEN TE ENCUENTRE EN INTERNET VEA EXACTAMENTE LO QUE ERES: UN NEGOCIO PROFESIONAL.</p>
      <p class="creative-cta">Tu competencia<br>ya se encuentra en internet. ¿Y tú?</p>
    </div>
    <div class="creative-right">
      <div class="image-stack">
        <img src="/laptop1.jpg" alt="Building exterior" class="image-base" />
        <img src="/laptop2.jpg" alt="Interior" class="image-reveal" />
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const section = document.getElementById('creative-section');
    const revealImage = section?.querySelector('.image-reveal');
    if (!section || !revealImage) return;

    let vh = window.innerHeight;

    window.addEventListener('resize', () => {
      vh = window.innerHeight;
    });

    let ticking = false;

    function updateCreativeReveal() {
      const rect = section.getBoundingClientRect();
      const sh = section.offsetHeight;
      const scrollable = sh - vh;
      if (scrollable <= 0) {
        ticking = false;
        return;
      }

      const cappedScrollable = Math.min(scrollable, vh);

      let progress = 0;
      if (rect.top < 0) {
        progress = Math.max(0, Math.min(1, (-rect.top) / cappedScrollable));
      }

      const revealInset = (1 - progress) * 100;
      revealImage.style.clipPath = `inset(${revealInset}% 0 0 0)`;

      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateCreativeReveal);
        ticking = true;
      }
    }, { passive: true });

    updateCreativeReveal();
  })();
</script>

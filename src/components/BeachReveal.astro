<style>
  #beach {
    position: relative;
    width: 100%;
    height: 100vh;
    margin-top: -30vh;
    overflow: hidden;
    background: transparent;
    z-index: 2;
  }

  #beach img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    will-change: clip-path;
  }

  /* ─── Sección blanca debajo de la playa ─── */
  #beach-white {
    position: relative;
    width: 100%;
    height: 30vh;
    background: #ffffff;
    box-sizing: border-box;
  }

  #white-titles {
    position: relative;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    will-change: transform;
  }

  #white-titles .left-title {
    position: absolute;
    top: 0;
    left: 50px;
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 448;
    font-size: clamp(48px, 5vw, 88px);
    letter-spacing: 0.05em;
    color: #080808;
    margin: 0;
  }

  #white-titles .right-title {
    position: absolute;
    top: 0;
    right: 50px;
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 448;
    font-size: clamp(48px, 5vw, 88px);
    letter-spacing: 0.05em;
    color: #080808;
    margin: 0;
  }

  #white-titles .description {
    position: absolute;
    top: 95%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 448;
    font-size: clamp(16px, 2vw, 22px);
    line-height: 1.6;
    text-transform: uppercase;
    text-align: center;
    color: #888888;
    margin: 0;
    width: 80%;
    max-width: 460px;
    white-space: pre-line;
  }

  /* ─── Sección de valor / misión ─── */
  #mission {
    width: 100%;
    height: 100vh;
    background: #ffffff;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 0;
    box-sizing: border-box;
  }

  #mission .mission-text {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 448;
    font-size: clamp(18px, 2.2vw, 26px);
    line-height: 1.7;
    text-transform: uppercase;
    color: #080808;
    margin: 0;
    max-width: 50%;
    padding: clamp(20px, 3vh, 40px) 0 0 clamp(50px, 5vw, 80px);
    box-sizing: border-box;
    white-space: pre-line;
  }

  @media (max-width: 768px) {
    #mission .mission-text {
      max-width: 85%;
      font-size: clamp(15px, 3.5vw, 20px);
      padding: 20px 0 0 25px;
    }
  }

  @media (max-width: 600px) {
    #white-titles .left-title {
      top: 30px;
      left: 25px;
      font-size: clamp(32px, 8vw, 48px);
    }
    #white-titles .right-title {
      top: 30px;
      right: 25px;
      font-size: clamp(32px, 8vw, 48px);
    }
    #white-titles .description {
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 90%;
      max-width: 340px;
      font-size: clamp(13px, 3.5vw, 18px);
    }
  }
</style>

<section id="beach">
  <img src="/beachBackground.jpg" alt="Beach background" />
</section>

<section id="beach-white">
  <div id="white-titles">
    <p class="left-title">DIGITALIZA</p>
    <p class="right-title">TU NEGOCIO</p>
    <p class="description">TU NEGOCIO EXISTE.
AHORA NECESITA EXISTIR EN INTERNET.</p>
  </div>
</section>

<section id="mission">
  <p class="mission-text">EN NEZZURA NO HACEMOS PÁGINAS, CONSTRUIMOS LA IMAGEN DIGITAL QUE TU MARCA SE MERECE. CADA DETALLE ESTÁ PENSADO PARA QUE QUIEN TE ENCUENTRE EN INTERNET VEA EXACTAMENTE LO QUE ERES: UN NEGOCIO PROFESIONAL, SERIO Y LISTO PARA CRECER.</p>
</section>

<script>
  (function () {
    const beachSection = document.getElementById('beach');
    const beachImg = document.querySelector('#beach img');

    if (beachSection && beachImg) {
      beachImg.style.clipPath = 'inset(100% 0 0 0)';

      let ticking = false;

      function updateReveal() {
        const rect = beachSection.getBoundingClientRect();
        const wh = window.innerHeight;

        // ─── Top reveal (existente): imagen se descubre de arriba a abajo ───
        const start = wh * 2;
        const end = 0;
        const total = start - end;
        const scrolled = start - rect.top;
        let progress = Math.max(0.6, Math.min(1, scrolled / total));

        const reveal = 100 - progress * 100;

        // ─── Bottom mask (nuevo): la imagen se desvanece suavemente por abajo ───
        // Se activa cuando la parte inferior de la playa supera el borde inferior del viewport
        const beachBottom = rect.bottom;
        const fadeStart = wh;             // empieza cuando el borde inferior de la playa está al final del viewport
        const fadeEnd = wh * 0.3;          // termina cuando está al 30% desde arriba
        const bottomProgress = Math.max(0, Math.min(1, (fadeStart - beachBottom) / (fadeStart - fadeEnd)));
        const bottomMask = bottomProgress * 35; // 0% → 35% de máscara inferior

        beachImg.style.clipPath = `inset(${reveal}% 0 ${bottomMask}% 0)`;

        // ─── Títulos sincronizados con la máscara inferior ───
        // Se mueven hacia arriba junto con el borde de la máscara
        const titles = document.getElementById('white-titles');
        if (titles) {
          const translateUp = bottomProgress * 35; // 0 → 35vh
          titles.style.transform = `translateY(-${translateUp}vh)`;
        }

        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(updateReveal);
          ticking = true;
        }
      });

      updateReveal();
    }
  })();
</script>

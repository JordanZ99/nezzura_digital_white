---
import BeachSection from './BeachSection.astro';
import WhiteTitles from './WhiteTitles.astro';
import CreativeSection from './CreativeSection.astro';
import StepsSection from './StepsSection.astro';
import CotizacionSection from './CotizacionSection.astro';
---

<BeachSection />
<WhiteTitles />
<CreativeSection />
<StepsSection />
<CotizacionSection />

<script>
  (function () {
    const beachSection = document.getElementById('beach');
    const beachImg = document.querySelector('#beach img');

    if (beachSection && beachImg) {
      let wh = window.innerHeight;
      beachImg.style.clipPath = 'inset(100% 0 0 0)';

      window.addEventListener('resize', () => {
        wh = window.innerHeight;
      });

      let ticking = false;

      function updateReveal() {
        const rect = beachSection.getBoundingClientRect();

        const start = wh * 2;
        const end = 0;
        const total = start - end;
        const scrolled = start - rect.top;
        let progress = Math.max(0.6, Math.min(1, scrolled / total));

        const reveal = 100 - progress * 100;

        const beachBottom = rect.bottom;
        const fadeStart = wh;
        const fadeEnd = wh * 0.3;
        const bottomProgress = Math.max(0, Math.min(1, (fadeStart - beachBottom) / (fadeStart - fadeEnd)));
        const bottomMask = bottomProgress * 50;
        const bottomZoom = bottomProgress * 0.2;
        const size = 1 + bottomZoom;

        beachImg.style.clipPath = `inset(${reveal}% 0 ${bottomMask}% 0)`;

        const translateUp = bottomProgress * 35;

        const isPhone = window.matchMedia('(max-width: 900px)').matches;
        if (isPhone) {
          const bw = document.getElementById('beach-white');
          const cs = document.getElementById('creative-section');
          if (bw) bw.style.transform = `translateY(-${translateUp}vh)`;
          if (cs) cs.style.marginTop = `-${translateUp}vh`;
        } else {
          const titles = document.getElementById('white-titles');
          if (titles) {
            titles.style.transform = `translateY(-${translateUp}vh)`;
          }
        }

        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(updateReveal);
          ticking = true;
        }
      }, { passive: true });

      updateReveal();
    }
  })();
</script>

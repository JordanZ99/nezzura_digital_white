<style>
  #beach {
    position: relative;
    width: 100%;
    height: 100vh;
    margin-top: -30vh;
    overflow: hidden;
    background: transparent;
    z-index: 2;
  }

  #beach img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    will-change: clip-path;
  }

  /* ─── Sección blanca debajo de la playa ─── */
  #beach-white {
    position: relative;
    width: 100%;
    height: 40vh;
    background: #ffffff;
    box-sizing: border-box;
  }

  #white-titles {
    position: relative;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    will-change: transform;
  }

  #white-titles .left-title {
    position: absolute;
    top: 0;
    left: 50px;
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 448;
    font-size: clamp(48px, 5vw, 88px);
    letter-spacing: 0.05em;
    color: #080808;
    margin: 0;
  }

  #white-titles .right-title {
    position: absolute;
    top: 0;
    right: 50px;
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 448;
    font-size: clamp(48px, 5vw, 88px);
    letter-spacing: 0.05em;
    color: #080808;
    margin: 0;
  }

  #white-titles .description {
    position: absolute;
    top: 115%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(16px, 1vw, 22px);
    line-height: 1.6;
    text-transform: uppercase;
    text-align: center;
    color: #888888;
    margin: 0;
    width: 80%;
    max-width: 460px;
    white-space: pre-line;
  }

  /* ─── Sección creativa con scroll pinning + image reveal ─── */
  #creative-section {
    position: relative;
    width: 100%;
    min-height: 200vh;
    background: #ffffff;
    box-sizing: border-box;
    z-index: 3;
  }

  #creative-section .creative-sticky {
    position: sticky;
    top: 0;
    height: 95vh;
    overflow: hidden;
    display: flex;
    box-sizing: border-box;
  }

  #creative-section .creative-left {
    width: 50%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    box-sizing: border-box;
    padding-top: 8vh;
  }

  #creative-section .creative-text {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(18px, 2.2vw, 26px);
    letter-spacing: 0.01em;
    line-height: 1.2;
    text-transform: uppercase;
    color: #080808;
    margin: 0;
    padding: clamp(20px, 3vh, 40px) 0 0 clamp(20px, 2vw, 40px);
    box-sizing: border-box;
    white-space: pre-line;
  }

  #creative-section .creative-cta {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(16px, 1vw, 22px);
    line-height: 1.2;
    text-transform: uppercase;
    color: #888888;
    margin: 100px 0 0 0;
    padding: 0 0 0 clamp(20px, 2vw, 40px);
    box-sizing: border-box;
    white-space: pre-line;
  }

  #creative-section .creative-right {
    width: 50%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    box-sizing: border-box;
    padding-top: 12vh;
  }

  #creative-section .image-stack {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }

  #creative-section .image-stack img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #creative-section .image-reveal {
    will-change: clip-path;
    clip-path: inset(100% 0 0 0);
  }

  @media (max-width: 768px) {
    #creative-section .creative-sticky {
      flex-direction: column;
    }
    #creative-section .creative-left {
      width: 100%;
      height: 50%;
      padding: 0;
      justify-content: center;
    }
    #creative-section .creative-text {
      max-width: 100%;
      font-size: clamp(15px, 3.5vw, 20px);
      padding: 20px 25px 0 25px;
    }
    #creative-section .creative-cta {
      font-size: clamp(13px, 3.5vw, 18px);
      padding: 0 25px 0 25px;
      margin: 20px 0 0 0;
    }
    #creative-section .creative-right {
      width: 100%;
      height: 50%;
      padding: 8px;
    }
  }

  @media (max-width: 600px) {
    #white-titles .left-title {
      top: 10px;
      left: 20px;
      font-size: clamp(28px, 7vw, 42px);
    }
    #white-titles .right-title {
      top: 10px;
      right: 20px;
      font-size: clamp(28px, 7vw, 42px);
    }
    #white-titles .description {
      top: 60%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 90%;
      max-width: 340px;
      font-size: clamp(12px, 3.2vw, 16px);
    }
  }
</style>

<section id="beach">
  <img src="/beachBackground.jpg" alt="Beach background" />
</section>

<section id="beach-white">
  <div id="white-titles">
    <p class="left-title">DIGITALIZA</p>
    <p class="right-title">TU NEGOCIO</p>
    <p class="description">78% de los negocios en México pierde clientes por no tener presencia digital profesional.</p>
  </div>
</section>

<section id="creative-section">
  <div class="creative-sticky">
    <div class="creative-left">
      <p class="creative-text">ESTRUCTURAS EFICIENTES, DISEÑOS PREMIUM. EN NEZZURA CONSTRUIMOS LA IMAGEN DIGITAL QUE TU MARCA SE MERECE. CADA DETALLE ESTÁ PENSADO PARA QUE QUIEN TE ENCUENTRE EN INTERNET VEA EXACTAMENTE LO QUE ERES: UN NEGOCIO PROFESIONAL.</p>
      <p class="creative-cta">Tu negocio existe.<br>Ahora necesita existir en internet.</p>
    </div>
    <div class="creative-right">
      <div class="image-stack">
        <img src="/laptop1.jpg" alt="Building exterior" class="image-base" />
        <img src="/laptop2.jpg" alt="Interior" class="image-reveal" />
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const beachSection = document.getElementById('beach');
    const beachImg = document.querySelector('#beach img');

    if (beachSection && beachImg) {
      let wh = window.innerHeight;
      beachImg.style.clipPath = 'inset(100% 0 0 0)';

      // Recalcular en resize/orientation para adaptarse a cambios de viewport
      window.addEventListener('resize', () => {
        wh = window.innerHeight;
      });

      let ticking = false;

      function updateReveal() {
        const rect = beachSection.getBoundingClientRect();

        // Top reveal: la imagen se destapa de arriba hacia abajo
        const start = wh * 2;
        const end = 0;
        const total = start - end;
        const scrolled = start - rect.top;
        let progress = Math.max(0.6, Math.min(1, scrolled / total));

        const reveal = 100 - progress * 100;

        // Bottom mask: se va tapando la parte inferior al salir del viewport
        const beachBottom = rect.bottom;
        const fadeStart = wh;
        const fadeEnd = wh * 0.3;
        const bottomProgress = Math.max(0, Math.min(1, (fadeStart - beachBottom) / (fadeStart - fadeEnd)));
        const bottomMask = bottomProgress * 35;

        beachImg.style.clipPath = `inset(${reveal}% 0 ${bottomMask}% 0)`;

        const translateUp = bottomProgress * 35;

        // ─── Mobile: pull sections up to avoid gaps, preserve sticky ───
        const isPhone = window.matchMedia('(max-width: 900px)').matches;
        if (isPhone) {
          const bw = document.getElementById('beach-white');
          const cs = document.getElementById('creative-section');
          if (bw) bw.style.transform = `translateY(-${translateUp}vh)`;
          if (cs) cs.style.marginTop = `-${translateUp}vh`;   // margin doesn't break sticky
        } else {
          // Desktop: existing parallax — translate only the titles inside
          const titles = document.getElementById('white-titles');
          if (titles) {
            titles.style.transform = `translateY(-${translateUp}vh)`;
          }
        }

        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(updateReveal);
          ticking = true;
        }
      }, { passive: true });

      updateReveal();
    }
  })();
</script>

<script>
  (function () {
    const section = document.getElementById('creative-section');
    const revealImage = section?.querySelector('.image-reveal');
    if (!section || !revealImage) return;

    let vh = window.innerHeight;

    window.addEventListener('resize', () => {
      vh = window.innerHeight;
    });

    let ticking = false;

    function updateCreativeReveal() {
      const rect = section.getBoundingClientRect();
      const sh = section.offsetHeight;
      const scrollable = sh - vh;
      if (scrollable <= 0) {
        ticking = false;
        return;
      }

      let progress = 0;
      if (rect.top < 0) {
        progress = Math.max(0, Math.min(1, (-rect.top) / scrollable));
      }

      const revealInset = (1 - progress) * 100;
      revealImage.style.clipPath = `inset(${revealInset}% 0 0 0)`;

      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateCreativeReveal);
        ticking = true;
      }
    }, { passive: true });

    updateCreativeReveal();
  })();
</script>

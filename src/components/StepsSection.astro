            <button class="step-next-btn" data-target="3" aria-label="Siguiente paso">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 8 12 16 22 8"></polyline></svg>
            </button>

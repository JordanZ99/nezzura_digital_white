<style>
  #steps-section {
    position: relative;
    width: 100%;
    background: transparent;
    z-index: 4;
    box-sizing: border-box;
    min-height: 500vh;
    margin-top: -200vh;
  }





  #steps-section .steps-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    box-sizing: border-box;
  }

  #steps-section .steps-mask::-webkit-scrollbar {
    display: none;
  }

  #steps-section .steps-mask {
    position: relative;
    width: 100%;
    height: 100%;
    background: #000;
    box-sizing: border-box;
    clip-path: inset(100% 0 0 0);
    will-change: clip-path;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    overflow-x: hidden;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  #steps-section .blackhole-bg {
    position: sticky;
    top: 0;
    width: 100vw;
    height: 100vh;
    flex-shrink: 0;
    margin-bottom: -100vh;
    margin-left: calc(-50vw + 50%);
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  #steps-section .blackhole-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    image-rendering: auto;
  }

  #steps-section .steps-inner {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    padding: 100px 40px 140px;
    box-sizing: border-box;
  }

  #steps-section .steps-header {
    text-align: center;
    margin-bottom: 100px;
  }

  #steps-section .steps-header h2 {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(28px, 3vw, 56px);
    letter-spacing: 0.05em;
    color: #ffffff;
    margin: 0 0 12px 0;
    text-transform: uppercase;
  }

  #steps-section .steps-header .steps-sub {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 400;
    font-size: clamp(15px, 1.1vw, 20px);
    line-height: 1.5;
    color: #777777;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (min-width: 769px) {
    #steps-section .steps-cards {
      max-width: 560px;
      margin: 0 auto;
    }
  }

  #steps-section .steps-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(400px, 50vh, 800px);
  }

  #steps-section .step-card {
    position: relative;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 24px;
    padding: clamp(28px, 3vw, 48px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    transition: box-shadow 0.3s ease, background 0.3s ease;
  }

  #steps-section .step-card:hover {
    background: rgba(255, 255, 255, 0.7);
  }

  #steps-section .step-next-btn,
  #steps-section .step-prev-btn {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    background: none;
    border: none;
    padding: 10px;
    cursor: pointer;
    color: white;
    opacity: 0.6;
    transition: opacity 0.3s ease, transform 0.3s ease;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #steps-section .step-next-btn {
    bottom: clamp(-90px, -15vh, -60px);
  }

  #steps-section .step-prev-btn {
    top: clamp(-90px, -15vh, -60px);
  }

  #steps-section .step-next-btn:hover {
    opacity: 1;
    transform: translate(-50%, 8px);
  }

  #steps-section .step-prev-btn:hover {
    opacity: 1;
    transform: translate(-50%, -8px);
  }

  #steps-section .step-next-btn svg,
  #steps-section .step-prev-btn svg {
    width: 54px;
    height: 54px;
  }

  #steps-section .step-card .step-num {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(24px, 2vw, 40px);
    color: #888888;
    margin: 0 0 12px 0;
    line-height: 1;
    text-transform: uppercase;
  }

  #steps-section .step-card .step-title {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(17px, 1.2vw, 22px);
    color: #000000;
    margin: 0 0 10px 0;
    text-transform: uppercase;
  }

  #steps-section .step-card .step-desc {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 400;
    font-size: clamp(13px, 0.9vw, 16px);
    line-height: 1.6;
    color: #555555;
    margin: 0;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    #steps-section .steps-inner {
      padding: 80px 24px;
      padding-top: 120px;
    }
    #steps-section .steps-header {
      margin-bottom: 40px;
    }
    #steps-section .steps-header h2 {
      font-size: clamp(24px, 7vw, 32px);
    }
    #steps-section .steps-header .steps-sub {
      font-size: clamp(12px, 3vw, 15px);
    }
    #steps-section .steps-cards {
      gap: clamp(240px, 40vh, 600px);
      margin-top: 25vh;
    }
    #steps-section .step-card .step-num {
      font-size: clamp(20px, 6vw, 28px);
    }
    #steps-section .step-card .step-title {
      font-size: clamp(15px, 3.5vw, 18px);
    }
    #steps-section .step-card .step-desc {
      font-size: clamp(12px, 3vw, 14px);
    }
  }
</style>

<section id="steps-section">
  <div class="steps-sticky">
    <div class="steps-mask">
      <div class="blackhole-bg">
        <img src="/assets/blackhole/scene00001.webp" alt="" id="blackhole-frame" />
      </div>
      <div class="steps-inner">
        <div class="steps-header">
          <h2>Sin tecnicismos, sin sorpresas</h2>
          <p class="steps-sub">Así trabajamos</p>
        </div>
        <div class="steps-cards">            <div class="step-card">
            <p class="step-num">01</p>
            <p class="step-title">Nos cuentas tu idea</p>
            <p class="step-desc">Una llamada de 30 minutos. Gratis y sin compromiso. Entendemos tu negocio, tu cliente ideal y tus objetivos para diseñar la soluci&oacute;n exacta que necesitas.</p>
            <button class="step-next-btn" data-target="1" aria-label="Siguiente paso">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 8 12 16 22 8"></polyline></svg>
            </button>
          </div>
          <div class="step-card">
            <button class="step-prev-btn" data-target="0" aria-label="Paso anterior">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 16 12 8 22 16"></polyline></svg>
            </button>
            <p class="step-num">02</p>
            <p class="step-title">Propuesta clara en menos de 24 horas</p>
            <p class="step-desc">Recibes una cotizaci&oacute;n formal con precio fijo, fecha de entrega definida y el alcance exacto de tu proyecto. Sin sorpresas ni letras chiquitas.</p>
            <button class="step-next-btn" data-target="2" aria-label="Siguiente paso">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 8 12 16 22 8"></polyline></svg>
            </button>
          </div>
          <div class="step-card">
            <button class="step-prev-btn" data-target="1" aria-label="Paso anterior">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 16 12 8 22 16"></polyline></svg>
            </button>
            <p class="step-num">03</p>
            <p class="step-title">Dise&ntilde;o primero, aprobaci&oacute;n y c&oacute;digo</p>
            <p class="step-desc">Creamos el prototipo visual de tu plataforma en Figma para que apruebes el dise&ntilde;o y hagas cambios antes de programar. Con entregas semanales, t&uacute; tienes el control total y nosotros la ejecuci&oacute;n impecable.</p>
            <button class="step-next-btn" data-target="3" aria-label="Siguiente paso">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 8 12 16 22 8"></polyline></svg>
            </button>
          </div>
          <div class="step-card">
            <button class="step-prev-btn" data-target="2" aria-label="Paso anterior">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 16 12 8 22 16"></polyline></svg>
            </button>
            <p class="step-num">04</p>
            <p class="step-title">Lanzamiento y soporte continuo</p>
            <p class="step-desc">Tu software sale al mundo de forma segura. Te incluimos 30 d&iacute;as de soporte real gratis y te dejamos configurado el plan de mantenimiento cloud para que tu negocio nunca deje de funcionar.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('steps-section');
    var mask = section && section.querySelector('.steps-mask');
    var inner = section && section.querySelector('.steps-inner');
    var cards = mask ? Array.from(mask.querySelectorAll('.step-card')) : [];
    var blackholeImg = document.getElementById('blackhole-frame');

    if (!section || !mask || !inner || cards.length === 0) return;

    var TOTAL_FRAMES = 96;
    var FRAME_STEP = 8;
    var BASE_PATH = '/assets/blackhole/';
    var CARD_SCALE_RANGE = 300;
    var CARD_SCALE_STRENGTH = 0.3;
    var EXTRA_SCROLL_OFFSET = 100;

    var ticking = false;
    var vh = window.innerHeight;
    var currentFrame = -1;
    var frameCache = {};
    var preloadStarted = false;
    var metrics = {
      sectionTop: 0,
      sectionHeight: 0,
      totalScrollable: 1,
      maxTranslate: 0
    };

    function getScrollY() {
      return window.scrollY || window.pageYOffset || 0;
    }

    function clamp01(value) {
      return Math.max(0, Math.min(1, value));
    }

    function padFrame(n) {
      var s = '00000' + n;
      return s.slice(-5);
    }

    function frameSrc(index) {
      var frameNum = 1 + index * FRAME_STEP;
      return BASE_PATH + 'scene' + padFrame(frameNum) + '.webp';
    }

    function getAbsoluteTop(el) {
      var top = 0;
      var node = el;
      while (node) {
        top += node.offsetTop || 0;
        node = node.offsetParent;
      }
      return top;
    }

    function recalcMetrics() {
      var prevTransform = inner.style.transform;
      inner.style.transform = 'translateY(0px)';
      metrics.sectionTop = getAbsoluteTop(section);
      metrics.sectionHeight = section.offsetHeight;
      metrics.totalScrollable = Math.max(1, metrics.sectionHeight - vh);
      metrics.maxTranslate = Math.max(0, inner.scrollHeight - vh + EXTRA_SCROLL_OFFSET);
      inner.style.transform = prevTransform;
    }

    function setFrameByProgress(progress) {
      if (!blackholeImg) return;
      var frameIndex = Math.min(TOTAL_FRAMES - 1, Math.round(progress * (TOTAL_FRAMES - 1)));
      if (frameIndex === currentFrame) return;
      currentFrame = frameIndex;
      blackholeImg.src = frameCache[frameIndex] ? frameCache[frameIndex].src : frameSrc(frameIndex);
    }

    function preloadAllFrames() {
      if (preloadStarted) return;
      preloadStarted = true;
      for (var i = 0; i < TOTAL_FRAMES; i++) {
        (function (idx) {
          var img = new Image();
          img.onload = function () {
            frameCache[idx] = img;
          };
          img.src = frameSrc(idx);
        })(i);
      }
    }

    var preloadObserver = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        preloadAllFrames();
        preloadObserver.disconnect();
      }
    }, { rootMargin: '1500px 0px 0px 0px' });
    preloadObserver.observe(section);

    function applyTransforms(progress, inSection) {
      var currentTranslate = progress * metrics.maxTranslate;
      inner.style.transform = 'translateY(-' + currentTranslate + 'px)';
      setFrameByProgress(progress);

      var centerViewport = vh / 2;
      for (var i = 0; i < cards.length; i++) {
        var card = cards[i];
        if (!inSection) {
          card.style.transform = 'scale(1)';
          continue;
        }
        var cardCenter = card.offsetTop + card.offsetHeight / 2 - currentTranslate;
        var distance = Math.abs(centerViewport - cardCenter);
        var scale = 1 - (CARD_SCALE_STRENGTH * Math.min(1, distance / CARD_SCALE_RANGE));
        card.style.transform = 'scale(' + scale.toFixed(3) + ')';
      }
    }

    function updateAllOnScroll() {
      var scrollY = getScrollY();
      var sectionTopInViewport = metrics.sectionTop - scrollY;
      var revealProgress = clamp01((vh - sectionTopInViewport) / vh);
      mask.style.clipPath = 'inset(' + ((1 - revealProgress) * 100) + '% 0 0 0)';

      var rawProgress = (scrollY - metrics.sectionTop) / metrics.totalScrollable;
      var progress = clamp01(rawProgress);
      var inSection = progress > 0 && progress < 1;

      applyTransforms(progress, inSection);
      ticking = false;
    }

    function requestUpdate() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(updateAllOnScroll);
    }

    window.addEventListener('scroll', requestUpdate, { passive: true });

    window.addEventListener('resize', function () {
      vh = window.innerHeight;
      currentFrame = -1;
      recalcMetrics();
      requestUpdate();
    }, { passive: true });

    recalcMetrics();
    updateAllOnScroll();

    var navBtns = mask ? Array.from(mask.querySelectorAll('.step-next-btn, .step-prev-btn')) : [];
    navBtns.forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        var targetIndex = parseInt(btn.getAttribute('data-target'), 10);
        if (isNaN(targetIndex) || !cards[targetIndex]) return;

        var targetCard = cards[targetIndex];
        var desiredTranslate = targetCard.offsetTop + targetCard.offsetHeight / 2 - vh / 2;
        var progress = metrics.maxTranslate > 0 ? desiredTranslate / metrics.maxTranslate : 0;
        progress = clamp01(progress);
        var targetScrollY = metrics.sectionTop + progress * metrics.totalScrollable;

        window.scrollTo({
          top: targetScrollY,
          behavior: 'smooth'
        });
      });
    });
  })();
</script>

<style>
  #steps-section {
    position: relative;
    width: 100%;
    background: transparent;
    z-index: 4;
    box-sizing: border-box;
    min-height: 300vh;
  }





  #steps-section .steps-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    box-sizing: border-box;
  }

  #steps-section .steps-mask::-webkit-scrollbar {
    display: none;
  }

  #steps-section .steps-mask {
    position: relative;
    width: 100%;
    height: 100%;
    background: #000;
    box-sizing: border-box;
    clip-path: inset(100% 0 0 0);
    will-change: clip-path;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    overflow-x: hidden;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  #steps-section .blackhole-bg {
    position: sticky;
    top: 0;
    width: 100vw;
    height: 100vh;
    flex-shrink: 0;
    margin-bottom: -100vh;
    margin-left: calc(-50vw + 50%);
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  #steps-section .blackhole-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    image-rendering: auto;
  }

  #steps-section .steps-inner {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    padding: 100px 40px 140px;
    box-sizing: border-box;
  }

  #steps-section .steps-header {
    text-align: center;
    margin-bottom: 100px;
  }

  #steps-section .steps-header h2 {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(28px, 3vw, 56px);
    letter-spacing: 0.05em;
    color: #ffffff;
    margin: 0 0 12px 0;
    text-transform: uppercase;
  }

  #steps-section .steps-header .steps-sub {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 400;
    font-size: clamp(15px, 1.1vw, 20px);
    line-height: 1.5;
    color: #777777;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (min-width: 769px) {
    #steps-section .steps-cards {
      max-width: 560px;
      margin: 0 auto;
    }
  }

  #steps-section .steps-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(200px, 25vh, 400px);
  }

  #steps-section .step-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 24px;
    padding: clamp(28px, 3vw, 48px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    transition: box-shadow 0.3s ease, background 0.3s ease;
  }

  #steps-section .step-card:hover {
    background: rgba(255, 255, 255, 0.7);
  }

  #steps-section .step-card .step-num {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(24px, 2vw, 40px);
    color: #888888;
    margin: 0 0 12px 0;
    line-height: 1;
    text-transform: uppercase;
  }

  #steps-section .step-card .step-title {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(17px, 1.2vw, 22px);
    color: #000000;
    margin: 0 0 10px 0;
    text-transform: uppercase;
  }

  #steps-section .step-card .step-desc {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 400;
    font-size: clamp(13px, 0.9vw, 16px);
    line-height: 1.6;
    color: #555555;
    margin: 0;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    #steps-section .steps-inner {
      padding: 80px 24px;
      padding-top: 120px;
    }
    #steps-section .steps-header {
      margin-bottom: 40px;
    }
    #steps-section .steps-header h2 {
      font-size: clamp(24px, 7vw, 32px);
    }
    #steps-section .steps-header .steps-sub {
      font-size: clamp(12px, 3vw, 15px);
    }
    #steps-section .steps-cards {
      gap: clamp(120px, 20vh, 300px);
    }
    #steps-section .step-card .step-num {
      font-size: clamp(20px, 6vw, 28px);
    }
    #steps-section .step-card .step-title {
      font-size: clamp(15px, 3.5vw, 18px);
    }
    #steps-section .step-card .step-desc {
      font-size: clamp(12px, 3vw, 14px);
    }
  }
</style>

<section id="steps-section">
  <div class="steps-sticky">
    <div class="steps-mask">
      <div class="blackhole-bg">
        <img src="/assets/blackhole/scene00001.png" alt="" id="blackhole-frame" />
      </div>
      <div class="steps-inner">
        <div class="steps-header">
          <h2>Sin tecnicismos, sin sorpresas</h2>
          <p class="steps-sub">Así trabajamos</p>
        </div>
        <div class="steps-cards">            <div class="step-card">
            <p class="step-num">01</p>
            <p class="step-title">Nos cuentas tu idea</p>
            <p class="step-desc">Una llamada de 30 minutos. Gratis y sin compromiso. Entendemos tu negocio, tu cliente ideal y tus objetivos para diseñar la soluci&oacute;n exacta que necesitas.</p>
          </div>
          <div class="step-card">
            <p class="step-num">02</p>
            <p class="step-title">Propuesta clara en menos de 24 horas</p>
            <p class="step-desc">Recibes una cotizaci&oacute;n formal con precio fijo, fecha de entrega definida y el alcance exacto de tu proyecto. Sin sorpresas ni letras chiquitas.</p>
          </div>
          <div class="step-card">
            <p class="step-num">03</p>
            <p class="step-title">Dise&ntilde;o primero, aprobaci&oacute;n y c&oacute;digo</p>
            <p class="step-desc">Creamos el prototipo visual de tu plataforma en Figma para que apruebes el dise&ntilde;o y hagas cambios antes de programar. Con entregas semanales, t&uacute; tienes el control total y nosotros la ejecuci&oacute;n impecable.</p>
          </div>
          <div class="step-card">
            <p class="step-num">04</p>
            <p class="step-title">Lanzamiento y soporte continuo</p>
            <p class="step-desc">Tu software sale al mundo de forma segura. Te incluimos 30 d&iacute;as de soporte real gratis y te dejamos configurado el plan de mantenimiento cloud para que tu negocio nunca deje de funcionar.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('steps-section');
    var mask = section && section.querySelector('.steps-mask');
    var inner = section && section.querySelector('.steps-inner');
    var cards = mask ? Array.from(mask.querySelectorAll('.step-card')) : [];
    var blackholeImg = document.getElementById('blackhole-frame');

    if (!section || !mask || !inner || cards.length === 0) return;

    var ticking = false;
    var vh = window.innerHeight;

    // Parámetros de animación
    var REVEAL_LIMIT = 0.3; // El revelado termina al 30% del scroll global

    // Parámetros de Agujero Negro
    var isMobile = window.innerWidth < 900;
    var TOTAL_FRAMES = isMobile ? 55 : 72;
    var FRAME_STEP = isMobile ? 12 : 2;
    var BASE_PATH = isMobile ? '/assets/blackholeMovil/' : '/assets/blackhole/';
    var currentFrame = -1;

    /* --- Caché de Fotogramas --- */
    var frameCache = {};
    var preloadStarted = false;

    function padFrame(n) {
      var s = '00000' + n;
      return s.slice(-5);
    }

    function frameSrc(index) {
      var frameNum = 1 + index * FRAME_STEP;
      return BASE_PATH + 'scene' + padFrame(frameNum) + '.png';
    }

    // Precarga agresiva cuando la sección está cerca
    function preloadAllFrames() {
      if (preloadStarted) return;
      preloadStarted = true;
      for (var i = 0; i < TOTAL_FRAMES; i++) {
        (function (idx) {
          var img = new Image();
          img.onload = function () {
            frameCache[idx] = img;
          };
          img.onerror = function () {
            setTimeout(function () {
              var retry = new Image();
              retry.onload = function () {
                frameCache[idx] = retry;
              };
              retry.src = frameSrc(idx);
            }, 2000);
          };
          img.src = frameSrc(idx);
        })(i);
      }
    }

    var preloadObserver = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        preloadAllFrames();
        preloadObserver.disconnect();
      }
    }, { rootMargin: '1500px 0px 0px 0px' });
    preloadObserver.observe(section);

    if (isMobile && blackholeImg) {
      blackholeImg.src = frameSrc(0);
    }

    function updateAllOnScroll() {
      var rect = section.getBoundingClientRect();
      var totalScrollable = rect.height - vh;
      
      // Si la sección no está en pantalla, no hacemos cálculos
      if (rect.top > vh || rect.bottom < 0) {
        ticking = false;
        return;
      }

      // 1. Calcular el progreso global (de 0 a 1)
      var scrolled = -rect.top;
      var globalProgress = Math.max(0, Math.min(1, scrolled / totalScrollable));

      // 2. FASE 1: Revelado de la máscara (0% al 30% del scroll)
      var revealProgress = Math.min(1, globalProgress / REVEAL_LIMIT);
      var revealInset = (1 - revealProgress) * 100;
      mask.style.clipPath = 'inset(' + revealInset + '% 0 0 0)';

      // 3. FASE 2: Movimiento de las tarjetas y Agujero Negro (30% al 100% del scroll)
      var contentProgress = 0;
      if (globalProgress > REVEAL_LIMIT) {
        contentProgress = (globalProgress - REVEAL_LIMIT) / (1 - REVEAL_LIMIT);
      }

      // --- DESLIZAMIENTO ARTIFICIAL DE TARJETAS (translateY) ---
      var innerHeight = inner.scrollHeight;
      var maxTranslate = Math.max(0, innerHeight - vh + 100);
      var currentTranslate = contentProgress * maxTranslate;
      inner.style.transform = 'translateY(-' + currentTranslate + 'px)';

      // --- ANIMACIÓN DEL AGUJERO NEGRO (Frames) ---
      if (blackholeImg) {
        var frameIndex = Math.min(TOTAL_FRAMES - 1, Math.round(contentProgress * (TOTAL_FRAMES - 1)));
        if (frameIndex !== currentFrame) {
          currentFrame = frameIndex;
          if (frameCache[frameIndex]) {
            blackholeImg.src = frameCache[frameIndex].src;
          } else {
            blackholeImg.src = frameSrc(frameIndex);
          }
        }
      }

      // --- EFECTO DE ESCALA EN LAS TARJETAS (Scale Zoom) ---
      var centerViewport = vh / 2;
      var range = 300;

      for (var i = 0; i < cards.length; i++) {
        var card = cards[i];
        var cardCenter = card.offsetTop + card.offsetHeight / 2 - currentTranslate;
        var distance = Math.abs(centerViewport - cardCenter);
        var scaleProgress = Math.min(1, distance / range);
        var scale = 1 - (1 - 0.7) * scaleProgress;
        card.style.transform = 'scale(' + scale.toFixed(3) + ')';
      }

      ticking = false;
    }

    // Escuchamos únicamente al scroll nativo de la ventana principal
    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(updateAllOnScroll);
        ticking = true;
      }
    }, { passive: true });

    window.addEventListener('resize', function () {
      vh = window.innerHeight;
      var newIsMobile = window.innerWidth < 900;
      if (newIsMobile !== isMobile) {
        isMobile = newIsMobile;
        TOTAL_FRAMES = isMobile ? 55 : 72;
        FRAME_STEP = isMobile ? 12 : 2;
        BASE_PATH = isMobile ? '/assets/blackholeMovil/' : '/assets/blackhole/';
        currentFrame = -1;
        frameCache = {};
        preloadStarted = false;
        preloadAllFrames();
      }
      if (!ticking) {
        requestAnimationFrame(updateAllOnScroll);
        ticking = true;
      }
    }, { passive: true });

    updateAllOnScroll();
  })();
</script>

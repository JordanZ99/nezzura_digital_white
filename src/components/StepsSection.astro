<style>
  #steps-section {
    position: relative;
    width: 100%;
    background: transparent;
    z-index: 4;
    box-sizing: border-box;
    min-height: 500vh;
    margin-top: -200vh;
  }





  #steps-section .steps-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    box-sizing: border-box;
  }

  #steps-section .steps-mask::-webkit-scrollbar {
    display: none;
  }

  #steps-section .steps-mask {
    position: relative;
    width: 100%;
    height: 100%;
    background: #000;
    box-sizing: border-box;
    clip-path: inset(100% 0 0 0);
    will-change: clip-path;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    overflow-x: hidden;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  #steps-section .blackhole-bg {
    position: sticky;
    top: 0;
    width: 100vw;
    height: 100vh;
    flex-shrink: 0;
    margin-bottom: -100vh;
    margin-left: calc(-50vw + 50%);
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  #steps-section .blackhole-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    image-rendering: auto;
  }

  #steps-section .steps-inner {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    padding: 100px 40px 140px;
    box-sizing: border-box;
  }

  #steps-section .steps-header {
    text-align: center;
    margin-bottom: 100px;
  }

  #steps-section .steps-header h2 {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(28px, 3vw, 56px);
    letter-spacing: 0.05em;
    color: #ffffff;
    margin: 0 0 12px 0;
    text-transform: uppercase;
  }

  #steps-section .steps-header .steps-sub {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 400;
    font-size: clamp(15px, 1.1vw, 20px);
    line-height: 1.5;
    color: #777777;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (min-width: 769px) {
    #steps-section .steps-cards {
      max-width: 560px;
      margin: 0 auto;
    }
  }

  #steps-section .steps-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(400px, 50vh, 800px);
  }

  #steps-section .step-card {
    position: relative;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 24px;
    padding: clamp(28px, 3vw, 48px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    transition: box-shadow 0.3s ease, background 0.3s ease;
  }

  #steps-section .step-card:hover {
    background: rgba(255, 255, 255, 0.7);
  }

  #steps-section .step-next-btn,
  #steps-section .step-prev-btn {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    background: none;
    border: none;
    padding: 10px;
    cursor: pointer;
    color: white;
    opacity: 0.6;
    transition: opacity 0.3s ease, transform 0.3s ease;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #steps-section .step-next-btn {
    bottom: clamp(-90px, -15vh, -60px);
  }

  #steps-section .step-prev-btn {
    top: clamp(-90px, -15vh, -60px);
  }

  #steps-section .step-next-btn:hover {
    opacity: 1;
    transform: translate(-50%, 8px);
  }

  #steps-section .step-prev-btn:hover {
    opacity: 1;
    transform: translate(-50%, -8px);
  }

  #steps-section .step-next-btn svg,
  #steps-section .step-prev-btn svg {
    width: 54px;
    height: 54px;
  }

  #steps-section .step-card .step-num {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(24px, 2vw, 40px);
    color: #888888;
    margin: 0 0 12px 0;
    line-height: 1;
    text-transform: uppercase;
  }

  #steps-section .step-card .step-title {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(17px, 1.2vw, 22px);
    color: #000000;
    margin: 0 0 10px 0;
    text-transform: uppercase;
  }

  #steps-section .step-card .step-desc {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 400;
    font-size: clamp(13px, 0.9vw, 16px);
    line-height: 1.6;
    color: #555555;
    margin: 0;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    #steps-section .steps-inner {
      padding: 80px 24px;
      padding-top: 120px;
    }
    #steps-section .steps-header {
      margin-bottom: 40px;
    }
    #steps-section .steps-header h2 {
      font-size: clamp(24px, 7vw, 32px);
    }
    #steps-section .steps-header .steps-sub {
      font-size: clamp(12px, 3vw, 15px);
    }
    #steps-section .steps-cards {
      gap: clamp(240px, 40vh, 600px);
      margin-top: 25vh;
    }
    #steps-section .step-card .step-num {
      font-size: clamp(20px, 6vw, 28px);
    }
    #steps-section .step-card .step-title {
      font-size: clamp(15px, 3.5vw, 18px);
    }
    #steps-section .step-card .step-desc {
      font-size: clamp(12px, 3vw, 14px);
    }
  }
</style>

<section id="steps-section">
  <div class="steps-sticky">
    <div class="steps-mask">
      <div class="blackhole-bg">
        <img src="/assets/blackhole/scene00001.webp" alt="" id="blackhole-frame" />
      </div>
      <div class="steps-inner">

---
import CotizacionSection from './CotizacionSection.astro';
---

<style>
  #steps-section {
    position: relative;
    width: 100%;
    min-height: 300vh;
    background: transparent;
    z-index: 4;
    box-sizing: border-box;
  }

  @media (min-width: 901px) {
    #steps-section {
      margin-top: -250vh;
    }
  }

  @media (max-width: 900px) {
    #steps-section {
      margin-top: -250vh;
    }
  }

  #steps-section .steps-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    box-sizing: border-box;
  }

  #steps-section .steps-mask::-webkit-scrollbar {
    display: none;
  }

  #steps-section .steps-mask {
    position: relative;
    width: 100%;
    height: 100%;
    background: #000;
    box-sizing: border-box;
    clip-path: inset(100% 0 0 0);
    will-change: clip-path;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    overflow-x: hidden;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 100px 40px 140px;
  }

  #steps-section .blackhole-bg {
    position: sticky;
    top: 0;
    width: 100vw;
    height: 100vh;
    flex-shrink: 0;
    margin-bottom: -100vh;
    margin-left: calc(-50vw + 50%);
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  #steps-section .blackhole-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    image-rendering: auto;
  }

  #steps-section .steps-inner {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  #steps-section .steps-header {
    text-align: center;
    margin-bottom: 100px;
  }

  #steps-section .steps-header h2 {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(28px, 3vw, 56px);
    letter-spacing: 0.05em;
    color: #ffffff;
    margin: 0 0 12px 0;
    text-transform: uppercase;
  }

  #steps-section .steps-header .steps-sub {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 400;
    font-size: clamp(15px, 1.1vw, 20px);
    line-height: 1.5;
    color: #777777;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (min-width: 769px) {
    #steps-section .steps-cards {
      max-width: 560px;
      margin: 0 auto;
    }
  }

  #steps-section .steps-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(200px, 25vh, 400px);
  }

  #steps-section .step-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 24px;
    padding: clamp(28px, 3vw, 48px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    transition: box-shadow 0.3s ease, background 0.3s ease;
  }

  #steps-section .step-card:hover {
    background: rgba(255, 255, 255, 0.7);
  }

  #steps-section .step-card .step-num {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(24px, 2vw, 40px);
    color: #888888;
    margin: 0 0 12px 0;
    line-height: 1;
    text-transform: uppercase;
  }

  #steps-section .step-card .step-title {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    font-size: clamp(17px, 1.2vw, 22px);
    color: #000000;
    margin: 0 0 10px 0;
    text-transform: uppercase;
  }

  #steps-section .step-card .step-desc {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 400;
    font-size: clamp(13px, 0.9vw, 16px);
    line-height: 1.6;
    color: #555555;
    margin: 0;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    #steps-section .steps-mask {
      padding: 80px 24px;
      justify-content: flex-start;
      padding-top: 120px;
    }
    #steps-section .steps-header {
      margin-bottom: 40px;
    }
    #steps-section .steps-header h2 {
      font-size: clamp(24px, 7vw, 32px);
    }
    #steps-section .steps-header .steps-sub {
      font-size: clamp(12px, 3vw, 15px);
    }
    #steps-section .steps-cards {
      gap: clamp(120px, 20vh, 300px);
    }
    #steps-section .step-card .step-num {
      font-size: clamp(20px, 6vw, 28px);
    }
    #steps-section .step-card .step-title {
      font-size: clamp(15px, 3.5vw, 18px);
    }
    #steps-section .step-card .step-desc {
      font-size: clamp(12px, 3vw, 14px);
    }
  }
</style>

<section id="steps-section">
  <div class="steps-sticky">
    <div class="steps-mask">
      <div class="blackhole-bg">
        <img src="/assets/blackhole/scene00001.png" alt="" id="blackhole-frame" />
      </div>
      <div class="steps-inner">
        <div class="steps-header">
          <h2>Sin tecnicismos, sin sorpresas</h2>
          <p class="steps-sub">Así trabajamos</p>
        </div>
        <div class="steps-cards">            <div class="step-card">
            <p class="step-num">01</p>
            <p class="step-title">Nos cuentas tu idea</p>
            <p class="step-desc">Una llamada de 30 minutos. Gratis y sin compromiso. Entendemos tu negocio, tu cliente ideal y tus objetivos para diseñar la soluci&oacute;n exacta que necesitas.</p>
          </div>
          <div class="step-card">
            <p class="step-num">02</p>
            <p class="step-title">Propuesta clara en menos de 24 horas</p>
            <p class="step-desc">Recibes una cotizaci&oacute;n formal con precio fijo, fecha de entrega definida y el alcance exacto de tu proyecto. Sin sorpresas ni letras chiquitas.</p>
          </div>
          <div class="step-card">
            <p class="step-num">03</p>
            <p class="step-title">Dise&ntilde;o primero, aprobaci&oacute;n y c&oacute;digo</p>
            <p class="step-desc">Creamos el prototipo visual de tu plataforma en Figma para que apruebes el dise&ntilde;o y hagas cambios antes de programar. Con entregas semanales, t&uacute; tienes el control total y nosotros la ejecuci&oacute;n impecable.</p>
          </div>
          <div class="step-card">
            <p class="step-num">04</p>
            <p class="step-title">Lanzamiento y soporte continuo</p>
            <p class="step-desc">Tu software sale al mundo de forma segura. Te incluimos 30 d&iacute;as de soporte real gratis y te dejamos configurado el plan de mantenimiento cloud para que tu negocio nunca deje de funcionar.</p>
          </div>
        </div>
        <CotizacionSection />
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('steps-section');
    var mask = section && section.querySelector('.steps-mask');
    if (!section || !mask) return;

    var vh = window.innerHeight;

    window.addEventListener('resize', function () {
      vh = window.innerHeight;
    });

    var ticking = false;

    var scrollLocked = true;
    var maskStyle = mask.style;

    function updateStepsReveal() {
      var rect = section.getBoundingClientRect();

      var revealStart = 0;
      var revealEnd = -vh;

      var progress = 0;
      if (rect.top < revealStart) {
        progress = Math.max(0, Math.min(1, (revealStart - rect.top) / (revealStart - revealEnd)));
      }

      var revealInset = (1 - progress) * 100;
      maskStyle.clipPath = 'inset(' + revealInset + '% 0 0 0)';

      if (revealInset > 0 && !scrollLocked) {
        scrollLocked = true;
        maskStyle.overflowY = 'hidden';
      } else if (revealInset <= 0 && scrollLocked) {
        scrollLocked = false;
        maskStyle.overflowY = 'auto';
      }

      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(updateStepsReveal);
        ticking = true;
      }
    }, { passive: true });

    updateStepsReveal();
  })();
</script>

<script>
  (function () {
    var mask = document.querySelector('.steps-mask');
    var cards = mask ? Array.from(mask.querySelectorAll('.step-card')) : [];
    if (!mask || cards.length === 0) return;

    var SCALE_MIN = 0.7;
    var ticking = false;
    var range = 400;

    function calculateRange() {
      if (cards.length > 1) {
        range = Math.abs(cards[1].offsetTop - cards[0].offsetTop);
      }
    }

    var blackholeImg = document.getElementById('blackhole-frame');
    var TOTAL_FRAMES = 72;
    var currentFrame = -1;

    function padFrame(n) {
      var s = '00000' + n;
      return s.slice(-5);
    }

    function frameSrc(index) {
      var frameNum = 1 + index * 2;
      return '/assets/blackhole/scene' + padFrame(frameNum) + '.png';
    }

    function updateCardScales() {
      var center = mask.scrollTop + mask.clientHeight / 2;

      for (var i = 0; i < cards.length; i++) {
        var card = cards[i];
        var cardCenter = card.offsetTop + card.offsetHeight / 2;
        var distance = Math.abs(center - cardCenter);
        var progress = Math.min(1, distance / range);
        var scale = 1 - (1 - SCALE_MIN) * progress;
        card.style.transform = 'scale(' + scale.toFixed(3) + ')';
      }

      if (blackholeImg) {
        var scrollable = mask.scrollHeight - mask.clientHeight;
        var scrollProgress = scrollable > 0 ? mask.scrollTop / scrollable : 0;
        var frameIndex = Math.min(TOTAL_FRAMES - 1, Math.round(scrollProgress * (TOTAL_FRAMES - 1)));
        if (frameIndex !== currentFrame) {
          currentFrame = frameIndex;
          blackholeImg.src = frameSrc(frameIndex);
        }
      }

      ticking = false;
    }

    calculateRange();

    mask.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(updateCardScales);
        ticking = true;
      }
    }, { passive: true });

    window.addEventListener('resize', function () {
      calculateRange();
      if (!ticking) {
        requestAnimationFrame(updateCardScales);
        ticking = true;
      }
    }, { passive: true });
  })();
</script>

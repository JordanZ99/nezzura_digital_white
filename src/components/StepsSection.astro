            <p class="step-desc">Tu software sale al mundo de forma segura. Te incluimos 30 d&iacute;as de soporte real gratis y te dejamos configurado el plan de mantenimiento cloud para que tu negocio nunca deje de funcionar.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('steps-section');
    var mask = section && section.querySelector('.steps-mask');
    var inner = section && section.querySelector('.steps-inner');
    var cards = mask ? Array.from(mask.querySelectorAll('.step-card')) : [];
    var blackholeImg = document.getElementById('blackhole-frame');

    if (!section || !mask || !inner || cards.length === 0) return;

    var ticking = false;
    var vh = window.innerHeight;

    // Parámetros de Agujero Negro
    var TOTAL_FRAMES = 96;
    var FRAME_STEP = 8;
    var BASE_PATH = '/assets/blackhole/';
    var currentFrame = -1;

    /* --- Caché de Fotogramas --- */
    var frameCache = {};
    var preloadStarted = false;

    function padFrame(n) {
      var s = '00000' + n;
      return s.slice(-5);
    }

    function frameSrc(index) {
      var frameNum = 1 + index * FRAME_STEP;
      return BASE_PATH + 'scene' + padFrame(frameNum) + '.webp';
    }

    // Precarga agresiva cuando la sección está cerca
    function preloadAllFrames() {
      if (preloadStarted) return;
      preloadStarted = true;
      for (var i = 0; i < TOTAL_FRAMES; i++) {
        (function (idx) {
          var img = new Image();
          img.onload = function () {
            frameCache[idx] = img;
          };
          img.onerror = function () {
            setTimeout(function () {
              var retry = new Image();
              retry.onload = function () {
                frameCache[idx] = retry;
              };
              retry.src = frameSrc(idx);
            }, 2000);
          };
          img.src = frameSrc(idx);
        })(i);
      }
    }

    var preloadObserver = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        preloadAllFrames();
        preloadObserver.disconnect();
      }
    }, { rootMargin: '1500px 0px 0px 0px' });
    preloadObserver.observe(section);

    var cachedMaxTranslate = -1;
    var stableScrollProgress = 0;
    var lastScrollY = window.scrollY || window.pageYOffset || 0;

    function getScrollY() {
      return window.scrollY || window.pageYOffset || 0;
    }

    function clamp01(value) {
      return Math.max(0, Math.min(1, value));
    }

    function getMaxTranslate() {
      if (cachedMaxTranslate < 0) {
        // Medir SIN transform activo para evitar que el layout se contamine
        var prevTransform = inner.style.transform;
        inner.style.transform = 'translateY(0px)';
        cachedMaxTranslate = Math.max(0, inner.scrollHeight - vh + 100);
        inner.style.transform = prevTransform;
      }
      return cachedMaxTranslate;
  }


    function updateAllOnScroll() {
    var scrollY = getScrollY();
    var sectionTop = section.offsetTop;
    var sectionHeight = section.offsetHeight;
    var sectionBottom = sectionTop + sectionHeight;
    var sectionTopInViewport = sectionTop - scrollY;
    var totalScrollable = Math.max(1, sectionHeight - vh);

    // Fase 1: revelado
    var revealProgress = clamp01((vh - sectionTopInViewport) / vh);
    mask.style.clipPath = 'inset(' + ((1 - revealProgress) * 100) + '% 0 0 0)';

    if (scrollY < sectionTop) {
      stableScrollProgress = 0;
      inner.style.transform = 'translateY(0px)';
      if (blackholeImg && currentFrame !== 0) {
        currentFrame = 0;
        blackholeImg.src = frameSrc(0);
      }
      for (var i = 0; i < cards.length; i++) cards[i].style.transform = 'scale(1)';
      lastScrollY = scrollY;
      ticking = false;
      return;
    }

    if (scrollY > sectionBottom) {
      stableScrollProgress = 1;
      lastScrollY = scrollY;
      ticking = false;
      return;
    }

    // Fase 2: scroll dentro de la sección
    var rawProgress = clamp01((scrollY - sectionTop) / totalScrollable);
    var direction = scrollY - lastScrollY;
    var EPSILON = 0.0005;
    var scrollProgress = rawProgress;

    // Android Chrome puede reportar retrocesos breves; estabilizamos por dirección real.
    if (direction > 0) {
      scrollProgress = Math.max(stableScrollProgress, rawProgress - EPSILON);
    } else if (direction < 0) {
      scrollProgress = Math.min(stableScrollProgress, rawProgress + EPSILON);
    } else {
      scrollProgress = stableScrollProgress;
    }

    scrollProgress = clamp01(scrollProgress);
    stableScrollProgress = scrollProgress;
    lastScrollY = scrollY;

    // ⬇️ Recalcular maxTranslate en cada tick (clave en móvil)
    var maxTranslate = getMaxTranslate();
    var currentTranslate = scrollProgress * maxTranslate;
    inner.style.transform = 'translateY(-' + currentTranslate + 'px)';

    // ⬇️ Frame basado en translateProgress, no en scrollProgress
    if (blackholeImg) {
      var translateProgress = maxTranslate > 0 ? currentTranslate / maxTranslate : scrollProgress;
      var frameIndex = Math.min(TOTAL_FRAMES - 1, Math.round(translateProgress * (TOTAL_FRAMES - 1)));
      if (frameIndex !== currentFrame) {
        currentFrame = frameIndex;
        blackholeImg.src = frameCache[frameIndex] ? frameCache[frameIndex].src : frameSrc(frameIndex);
      }
    }

    // Escala de tarjetas (sin cambios)
    var centerViewport = vh / 2;
    var range = 300;
    for (var i = 0; i < cards.length; i++) {
      var card = cards[i];
      var cardCenter = card.offsetTop + card.offsetHeight / 2 - currentTranslate;
      var distance = Math.abs(centerViewport - cardCenter);
      var scale = 1 - (0.3 * Math.min(1, distance / range));
      card.style.transform = 'scale(' + scale.toFixed(3) + ')';
    }

    ticking = false;
  }

    // Escuchamos únicamente al scroll nativo de la ventana principal
    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(updateAllOnScroll);
        ticking = true;
      }
    }, { passive: true });

    window.addEventListener('resize', function () {
    vh = window.innerHeight;
      cachedMaxTranslate = -1;   // ← forzar re-medición
      currentFrame = -1;
      stableScrollProgress = 0;
      lastScrollY = getScrollY();
      if (!ticking) {
        requestAnimationFrame(updateAllOnScroll);
        ticking = true;
      }
    }, { passive: true });

    updateAllOnScroll();

    // --- LOGICA DE BOTONES SIGUIENTE Y ANTERIOR --- 
    var navBtns = mask ? Array.from(mask.querySelectorAll('.step-next-btn, .step-prev-btn')) : [];
    navBtns.forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var targetIndex = parseInt(btn.getAttribute('data-target'), 10);
        if (isNaN(targetIndex)) return;

        var rect = section.getBoundingClientRect();
        var absoluteTop = window.scrollY + rect.top;
        var totalScrollable = rect.height - vh;
        var maxTranslate = Math.max(0, inner.scrollHeight - vh + 100);

        var progress = 1; // Default to end of section if index is out of bounds
        
        if (cards[targetIndex]) {
          var targetCard = cards[targetIndex];
          var desiredTranslate = targetCard.offsetTop + targetCard.offsetHeight / 2 - vh / 2;
          progress = maxTranslate > 0 ? desiredTranslate / maxTranslate : 0;
        }

        progress = Math.max(0, Math.min(1, progress));
        var targetScrollY = absoluteTop + progress * totalScrollable;
        
        window.scrollTo({
          top: targetScrollY,
          behavior: 'smooth'
        });
      });
    });
  })();
</script>

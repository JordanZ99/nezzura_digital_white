          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('steps-section');
    var mask = section && section.querySelector('.steps-mask');
    if (!section || !mask) return;

    var vh = window.innerHeight;

    window.addEventListener('resize', function () {
      vh = window.innerHeight;
      adjustSectionHeight();
    });

    var ticking = false;

    var scrollLocked = true;
    var maskStyle = mask.style;

    function updateStepsReveal() {
      var rect = section.getBoundingClientRect();

      var revealStart = 0;
      var revealEnd = -vh;

      var progress = 0;
      if (rect.top < revealStart) {
        progress = Math.max(0, Math.min(1, (revealStart - rect.top) / (revealStart - revealEnd)));
      }

      var revealInset = (1 - progress) * 100;
      maskStyle.clipPath = 'inset(' + revealInset + '% 0 0 0)';

      if (revealInset > 0 && !scrollLocked) {
        scrollLocked = true;
        maskStyle.overflowY = 'hidden';
      } else if (revealInset <= 0 && scrollLocked) {
        scrollLocked = false;
        maskStyle.overflowY = 'auto';
      }

      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(updateStepsReveal);
        ticking = true;
      }
    }, { passive: true });

    /* --- Dynamic height: section height = reveal scroll (1vh) + mask internal scroll --- */
    function adjustSectionHeight() {
      var scrollable = mask.scrollHeight - mask.clientHeight;
      /* The section needs: 1 viewport height for the reveal animation + the mask's internal scroll */
      var neededHeight = vh + scrollable;
      section.style.minHeight = neededHeight + 'px';
      /* Pull the section up so the reveal animation starts at the right scroll position */
      section.style.marginTop = '-' + (neededHeight - vh) + 'px';
    }

    adjustSectionHeight();
    window.addEventListener("load", adjustSectionHeight);

    updateStepsReveal();
  })();
</script>

<script>
  (function () {
    var section = document.getElementById('steps-section');
    var mask = section && section.querySelector('.steps-mask');
    var cards = mask ? Array.from(mask.querySelectorAll('.step-card')) : [];
    if (!section || !mask || cards.length === 0) return;

    var SCALE_MIN = 0.7;
    var ticking = false;
    var range = 400;

    function calculateRange() {
      if (cards.length > 1) {
        range = Math.abs(cards[1].offsetTop - cards[0].offsetTop);
      }
    }

    var blackholeImg = document.getElementById('blackhole-frame');
    var isMobile = window.innerWidth < 900;
    var TOTAL_FRAMES = isMobile ? 55 : 72;
    var FRAME_STEP = isMobile ? 12 : 2;
    var BASE_PATH = isMobile ? '/assets/blackholeMovil/' : '/assets/blackhole/';
    var currentFrame = -1;

    /* --- Frame cache --- */
    var frameCache = {};
    var preloadStarted = false;

    function padFrame(n) {
      var s = '00000' + n;
      return s.slice(-5);
    }

    function frameSrc(index) {
      var frameNum = 1 + index * FRAME_STEP;
      return BASE_PATH + 'scene' + padFrame(frameNum) + '.png';
    }

    /* Aggressive preloading: start when section is 1500px away */
    function preloadAllFrames() {
      if (preloadStarted) return;
      preloadStarted = true;
      var loaded = 0;
      for (var i = 0; i < TOTAL_FRAMES; i++) {
        (function(idx) {
          var img = new Image();
          img.onload = function () {
            frameCache[idx] = img;
            loaded++;
          };
          img.onerror = function () {
            /* Retry once after 2s */
            setTimeout(function () {
              var retry = new Image();
              retry.onload = function () {
                frameCache[idx] = retry;
              };
              retry.src = frameSrc(idx);
            }, 2000);
            loaded++;
          };
          img.src = frameSrc(idx);
        })(i);
      }
    }

    var preloadObserver = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        preloadAllFrames();
        preloadObserver.disconnect();
      }
    }, { rootMargin: '1500px 0px 0px 0px' });
    preloadObserver.observe(section);

    if (isMobile && blackholeImg) {
      blackholeImg.src = frameSrc(0);
    }

    function updateCardScales() {
      var center = mask.scrollTop + mask.clientHeight / 2;

      for (var i = 0; i < cards.length; i++) {
        var card = cards[i];
        var cardCenter = card.offsetTop + card.offsetHeight / 2;
        var distance = Math.abs(center - cardCenter);
        var progress = Math.min(1, distance / range);
        var scale = 1 - (1 - SCALE_MIN) * progress;
        card.style.transform = 'scale(' + scale.toFixed(3) + ')';
      }

      if (blackholeImg) {
        var scrollable = mask.scrollHeight - mask.clientHeight;
        var scrollProgress = scrollable > 0 ? mask.scrollTop / scrollable : 0;
        var frameIndex = Math.min(TOTAL_FRAMES - 1, Math.round(scrollProgress * (TOTAL_FRAMES - 1)));
        if (frameIndex !== currentFrame) {
          currentFrame = frameIndex;
          /* Use cached image src if available (instant from memory), else fallback */
          if (frameCache[frameIndex]) {
            blackholeImg.src = frameCache[frameIndex].src;
          } else {
            blackholeImg.src = frameSrc(frameIndex);
          }
        }
      }

      ticking = false;
    }

    calculateRange();

    mask.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(updateCardScales);
        ticking = true;
      }
    }, { passive: true });

    window.addEventListener('resize', function () {
      var newIsMobile = window.innerWidth < 900;
      if (newIsMobile !== isMobile) {
        isMobile = newIsMobile;
        TOTAL_FRAMES = isMobile ? 55 : 72;
        FRAME_STEP = isMobile ? 12 : 2;
        BASE_PATH = isMobile ? '/assets/blackholeMovil/' : '/assets/blackhole/';
        currentFrame = -1;
        frameCache = {};
        preloadStarted = false;
        preloadAllFrames();
      }
      calculateRange();
      if (!ticking) {
        requestAnimationFrame(updateCardScales);
        ticking = true;
      }
    }, { passive: true });
  })();
</script>

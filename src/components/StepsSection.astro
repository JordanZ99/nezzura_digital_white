            </button>
          </div>
          <div class="step-card">
            <button class="step-prev-btn" data-target="1" aria-label="Paso anterior">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 16 12 8 22 16"></polyline></svg>
            </button>
            <p class="step-num">03</p>
            <p class="step-title">Dise&ntilde;o primero, aprobaci&oacute;n y c&oacute;digo</p>

---
import FluidGlassCursor from '../components/FluidGlassCursor.tsx';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nezzura</title>
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      -webkit-tap-highlight-color: transparent;
    }

    html, body {
      width: 100%;
      height: 100%; 
      overflow-x: clip; 
      background: #ffffff;
    }

    /* Ocultar cursor nativo solo cuando el cursor de vidrio está activo */
    body.glass-cursor-active,
    body.glass-cursor-active *,
    body.glass-cursor-active *::before,
    body.glass-cursor-active *::after {
      cursor: none !important;
    }
  </style>
</head>
<body>
  <slot />
  <!-- Cursor de vidrio fluido — solo se monta en el cliente (Three.js no corre en SSR) -->
  <FluidGlassCursor client:only="react" />
</body>
</html>

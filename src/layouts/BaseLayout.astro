<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nezzura</title>
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html, body {
      width: 100%;
      /* 1. Cambiamos min-height por height para heredar correctamente la altura de la página */
      height: 100%; 
      
      /* 2. Dejamos solo el clip horizontal para las letras gigantes */
      overflow-x: clip; 
      
      /* ❌ ELIMINADO: overflow-y: auto; (Esto causaba que no se quedara pinneado) */
      
      background: #ffffff;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
